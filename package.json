{
  "name": "shadow-circuit",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "test:levels": "tsx scripts/level-walkthrough.ts",
    "test:browser": "tsx scripts/browser-smoke.ts",
    "test:mobile": "tsx scripts/mobile-smoke.ts",
    "debug:hero-animation": "tsx scripts/hero-animation-debug.ts",
    "debug:enemy-sentry": "tsx scripts/enemy-sentry-debug.ts",
    "assets:meshy-objectives": "tsx scripts/generate-meshy-objectives.ts",
    "assets:meshy-characters": "tsx scripts/generate-meshy-characters.ts",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "verify": "npm run test:run && npm run test:levels && npm run build"
  },
  "dependencies": {
    "@types/three": "^0.176.0",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pngjs": "^6.0.5",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
